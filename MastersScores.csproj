<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Data.Tables" Version="12.11.0" />
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" Version="3.1.0" />
    <PackageReference Include="Microsoft.Azure.SignalR" Version="1.33.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="data\**\*.json" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Run 'dotnet publish /p:DeployInfra=true' or check the box in VS publish to also provision Azure infra -->
  <Target Name="DeployInfra" AfterTargets="MSDeployPublish" Condition="'$(DeployInfra)'=='true'">
    <Exec Command="powershell -File &quot;$(MSBuildProjectDirectory)\infra\deploy.ps1&quot;" />
  </Target>

</Project>
